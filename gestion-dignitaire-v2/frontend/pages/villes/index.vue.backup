<template>
  <DashboardLayout>
    <!-- Header moderne avec gradient gabonais -->
    <header class="bg-gradient-to-r from-gabon-green-600 via-gabon-yellow-500 to-gabon-blue-600 shadow-lg p-6 mb-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-2">
          <svg class="w-8 h-8 text-white drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <h1 class="text-3xl font-bold text-white drop-shadow-lg">Gestion des Villes</h1>
        </div>
        <p class="text-white text-sm opacity-95 drop-shadow">Gérer les villes et leurs informations</p>
      </div>
    </header>

    <section class="max-w-7xl mx-auto px-4 pb-8">
      <!-- Barre de recherche et filtres -->
      <div class="bg-white rounded-xl shadow-lg p-4 mb-6">
        <div class="flex flex-col md:flex-row gap-4 items-center">
          <!-- Recherche -->
          <div class="flex-1 relative w-full">
            <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input
              v-model="filters.search"
              @input="loadVilles"
              type="text"
              placeholder="Rechercher une ville..."
              class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gabon-green-500 focus:border-transparent transition"
            >
          </div>

          <!-- Filtre par pays -->
          <div class="w-full md:w-64">
            <select
              v-model="filters.pays_id"
              @change="loadVilles"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gabon-blue-500 focus:border-transparent transition"
            >
              <option value="">Tous les pays</option>
              <option v-for="p in paysList" :key="p.id" :value="p.id">
                {{ p.nom }}
              </option>
            </select>
          </div>
          
          <!-- Bouton Ajouter -->
          <button
            @click="openModal()"
            class="bg-gradient-to-r from-gabon-green-600 to-gabon-green-700 hover:from-gabon-green-700 hover:to-gabon-green-800 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 flex items-center gap-2 whitespace-nowrap"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Ajouter une ville
          </button>
        </div>
      </div>

      <!-- Loader -->
      <div v-if="loading" class="flex justify-center items-center py-20">
        <div class="relative">
          <div class="animate-spin rounded-full h-16 w-16 border-4 border-gray-200"></div>
          <div class="animate-spin rounded-full h-16 w-16 border-4 border-gabon-green-600 border-t-transparent absolute top-0 left-0"></div>
        </div>
      </div>

      <!-- Tableau moderne -->
      <div v-else class="bg-white rounded-xl shadow-lg overflow-hidden">
        <div v-if="paginatedVilles.length > 0" class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gradient-to-r from-gray-50 to-gray-100">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Ville</th>
                <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Pays</th>
                <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Drapeau</th>
                <th class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Province</th>
                <th class="px-6 py-4 text-center text-xs font-bold text-gray-700 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <tr v-for="v in paginatedVilles" :key="v.id" class="hover:bg-gabon-green-50 transition-colors duration-150">
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm font-semibold text-gray-900">{{ v.nom }}</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="text-sm text-gray-700">{{ v.pays_nom || 'N/A' }}</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <img 
                    v-if="v.pays_code_iso" 
                    :src="`https://flagcdn.com/w40/${v.pays_code_iso.toLowerCase()}.png`" 
                    :alt="`${v.pays_nom} flag`"
                    class="inline-block h-6 rounded shadow-sm"
                    @error="$event.target.style.display='none'"
                  >
                  <span v-else class="text-gray-400 text-sm">N/A</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span v-if="v.region_nom" class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gabon-blue-100 text-gabon-blue-800">
                    {{ v.region_nom }}
                  </span>
                  <span v-else class="text-gray-400 text-sm">N/A</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <div class="flex items-center justify-center gap-2">
                    <button
                      @click="openModal(v)"
                      class="inline-flex items-center gap-1 bg-gabon-blue-50 hover:bg-gabon-blue-100 text-gabon-blue-700 font-semibold px-3 py-2 rounded-lg transition-colors"
                      title="Modifier"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                      </svg>
                      Modifier
                    </button>
                    <button
                      @click="deleteVille(v.id)"
                      class="inline-flex items-center gap-1 bg-red-50 hover:bg-red-100 text-red-700 font-semibold px-3 py-2 rounded-lg transition-colors"
                      title="Supprimer"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                      Supprimer
                    </button>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <!-- Message vide -->
        <div v-else class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <p class="mt-4 text-gray-500 text-lg">Aucune ville enregistrée</p>
        </div>

        <!-- Pagination -->
        <Pagination
          v-if="villes.length > 0"
          :current-page="currentPage"
          :total-pages="totalPages"
          :start-index="startIndex"
          :end-index="endIndex"
          :total="villes.length"
          @update:current-page="currentPage = $event"
        />
      </div>
    </section>

    <!-- Modal d'ajout/modification -->
    <div
      v-if="showModal"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
      @click.self="closeModal"
    >
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <!-- Header du modal -->
        <div class="bg-gradient-to-r from-gabon-green-600 to-gabon-green-700 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
          <h4 class="text-xl font-bold text-white flex items-center gap-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            {{ selectedVille ? 'Modifier' : 'Ajouter' }} une ville
          </h4>
          <button @click="closeModal" class="text-white hover:text-gray-200 transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Formulaire -->
        <form @submit.prevent="saveVille" class="p-6">
          <div class="space-y-4">
            <!-- Nom de la ville -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Nom de la ville <span class="text-red-500">*</span>
              </label>
              <input
                v-model="form.nom"
                type="text"
                required
                class="w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-gabon-green-500 focus:border-transparent transition"
                placeholder="Ex: Libreville, Paris, New York..."
              >
            </div>

            <!-- Pays -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Pays <span class="text-red-500">*</span>
              </label>
              <select
                v-model="form.pays_id"
                @change="filterProvincesByPays"
                required
                class="w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-gabon-green-500 focus:border-transparent transition"
              >
                <option value="">-- Sélectionner un pays --</option>
                <option v-for="p in paysList" :key="p.id" :value="p.id">
                  {{ p.nom }}
                </option>
              </select>
            </div>

            <!-- Province -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2 flex items-center justify-between">
                <span>Province</span>
                <button
                  type="button"
                  @click="openProvinceModal"
                  class="text-xs bg-gabon-blue-50 hover:bg-gabon-blue-100 text-gabon-blue-700 px-3 py-1 rounded-lg transition-colors flex items-center gap-1"
                >
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  Ajouter une province
                </button>
              </label>
              <select
                v-model="form.region_id"
                :disabled="!form.pays_id"
                :class="['w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-gabon-green-500 focus:border-transparent transition', !form.pays_id ? 'bg-gray-100 text-gray-600 cursor-not-allowed' : 'bg-white']"
              >
                <option value="">-- Sélectionner une province --</option>
                <option v-for="province in filteredProvinces" :key="province.id" :value="province.id">
                  {{ province.nom }}
                </option>
              </select>
              <p v-if="!form.pays_id" class="text-xs text-gray-500 mt-1">
                Sélectionnez d'abord un pays
              </p>
              <p v-else class="text-xs text-gabon-blue-600 mt-1">
                La province n'existe pas ? Cliquez sur "Ajouter une province" pour la créer
              </p>
            </div>
          </div>

          <!-- Boutons d'action -->
          <div class="flex gap-3 mt-6 pt-4 border-t">
            <button
              type="button"
              @click="closeModal"
              class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-6 py-3 rounded-lg transition"
            >
              Annuler
            </button>
            <button
              type="submit"
              class="flex-1 bg-gradient-to-r from-gabon-green-600 to-gabon-green-700 hover:from-gabon-green-700 hover:to-gabon-green-800 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:shadow-lg transition-all duration-300"
            >
              {{ selectedVille ? 'Modifier' : 'Enregistrer' }}
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Modal d'ajout de province -->
    <div
      v-if="showProvinceModal"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
      @click.self="closeProvinceModal"
    >
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
        <!-- Header du modal -->
        <div class="bg-gradient-to-r from-gabon-blue-600 to-gabon-blue-700 px-6 py-4 flex items-center justify-between">
          <h4 class="text-xl font-bold text-white flex items-center gap-2">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Ajouter une province
          </h4>
          <button @click="closeProvinceModal" class="text-white hover:text-gray-200 transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Formulaire province -->
        <form @submit.prevent="saveProvince" class="p-6">
          <div class="space-y-4">
            <!-- Nom de la province -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Nom de la province <span class="text-red-500">*</span>
              </label>
              <input
                v-model="provinceForm.nom"
                type="text"
                required
                class="w-full border rounded-lg px-4 py-3 focus:ring-2 focus:ring-gabon-blue-500 focus:border-transparent transition"
                placeholder="Ex: Île-de-France, Provence, Estuaire..."
              >
            </div>

            <!-- Pays (lecture seule) -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Pays
              </label>
              <input
                :value="getSelectedPaysName()"
                type="text"
                readonly
                class="w-full border rounded-lg px-4 py-3 bg-gray-100 text-gray-600 cursor-not-allowed"
              >
            </div>
          </div>

          <!-- Boutons d'action -->
          <div class="flex gap-3 mt-6 pt-4 border-t">
            <button
              type="button"
              @click="closeProvinceModal"
              class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-6 py-3 rounded-lg transition"
            >
              Annuler
            </button>
            <button
              type="submit"
              class="flex-1 bg-gradient-to-r from-gabon-blue-600 to-gabon-blue-700 hover:from-gabon-blue-700 hover:to-gabon-blue-800 text-white font-semibold px-6 py-3 rounded-lg shadow-md hover:shadow-lg transition-all duration-300"
            >
              Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>
  </DashboardLayout>
</template>


<script setup>
import { ref, computed, onMounted } from 'vue'
import Pagination from '~/components/Pagination.vue'

definePageMeta({
  middleware: 'auth'
})

const authStore = useAuthStore()

const villes = ref([])
const paysList = ref([])
const provinces = ref([])
const loading = ref(false)
const showModal = ref(false)
const showProvinceModal = ref(false)
const selectedVille = ref(null)
const currentPage = ref(1)
const itemsPerPage = 10

const form = ref({
  nom: '',
  pays_id: '',
  region_id: ''
})

const provinceForm = ref({
  nom: '',
  pays_nom: ''
})

const filters = ref({
  search: '',
  pays_id: ''
})

const filteredProvinces = ref([])

// Pagination
const paginatedVilles = computed(() => {
  const start = (currentPage.value - 1) * itemsPerPage
  const end = start + itemsPerPage
  return villes.value.slice(start, end)
})

const totalPages = computed(() => Math.ceil(villes.value.length / itemsPerPage))
const startIndex = computed(() => (currentPage.value - 1) * itemsPerPage + 1)
const endIndex = computed(() => Math.min(currentPage.value * itemsPerPage, villes.value.length))

// Charger les villes
async function loadVilles() {
  loading.value = true
  try {
    const config = useRuntimeConfig()
    const token = authStore.token
    const response = await $fetch(`${config.public.apiBase}/villes-crud`, {
      params: { 
        search: filters.value.search,
        pays_id: filters.value.pays_id
      },
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json'
      }
    })
    villes.value = response || []
  } catch (error) {
    console.error('Erreur lors du chargement des villes:', error)
    villes.value = []
  } finally {
    loading.value = false
  }
}

// Charger les pays
async function loadPays() {
  try {
    const config = useRuntimeConfig()
    const token = authStore.token
    const response = await $fetch(`${config.public.apiBase}/pays-crud`, {
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json'
      }
    })
    paysList.value = response || []
  } catch (error) {
    console.error('Erreur lors du chargement des pays:', error)
    paysList.value = []
  }
}

// Charger les provinces
async function loadProvinces() {
  try {
    const config = useRuntimeConfig()
    const token = authStore.token
    const response = await $fetch(`${config.public.apiBase}/regions-crud`, {
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json'
      }
    })
    // Filtrer uniquement les provinces (type = 'province')
    provinces.value = (response || []).filter(r => r.type === 'province')
  } catch (error) {
    console.error('Erreur lors du chargement des provinces:', error)
    provinces.value = []
  }
}

// Filtrer les provinces par pays
function filterProvincesByPays() {
  if (!form.value.pays_id) {
    filteredProvinces.value = []
    return
  }
  
  const selectedPays = paysList.value.find(p => p.id == form.value.pays_id)
  if (!selectedPays) {
    filteredProvinces.value = []
    return
  }
  
  // Filtrer uniquement les provinces associées à ce pays
  filteredProvinces.value = provinces.value.filter(p => p.pays_nom === selectedPays.nom)
}

// Ouvrir le modal
function openModal(ville = null) {
  selectedVille.value = ville
  
  if (ville) {
    form.value = {
      nom: ville.nom,
      pays_id: ville.pays_id || '',
      region_id: ville.region_id || ''
    }
    filterProvincesByPays()
  } else {
    form.value = {
      nom: '',
      pays_id: '',
      region_id: ''
    }
    filteredProvinces.value = []
  }
  
  showModal.value = true
}

// Fermer le modal
function closeModal() {
  showModal.value = false
  selectedVille.value = null
  form.value = {
    nom: '',
    pays_id: '',
    region_id: ''
  }
}

// Enregistrer une ville
async function saveVille() {
  try {
    const config = useRuntimeConfig()
    const token = authStore.token
    const url = selectedVille.value
      ? `${config.public.apiBase}/villes-crud/${selectedVille.value.id}`
      : `${config.public.apiBase}/villes-crud`
    
    const method = selectedVille.value ? 'PUT' : 'POST'
    
    await $fetch(url, {
      method,
      body: form.value,
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json',
        'Content-Type': 'application/json'
      }
    })
    
    const { $swal } = useNuxtApp()
    $swal.fire({
      icon: 'success',
      title: 'Succès',
      text: selectedVille.value ? 'Ville modifiée avec succès' : 'Ville ajoutée avec succès',
      timer: 2000,
      showConfirmButton: false
    })
    
    closeModal()
    await loadVilles()
  } catch (error) {
    console.error('Erreur lors de l\'enregistrement:', error)
    const { $swal } = useNuxtApp()
    $swal.fire({
      icon: 'error',
      title: 'Erreur',
      text: 'Une erreur est survenue lors de l\'enregistrement'
    })
  }
}

// Supprimer une ville
async function deleteVille(id) {
  const { $swal } = useNuxtApp()
  const result = await $swal.fire({
    title: 'Êtes-vous sûr ?',
    text: 'Cette action est irréversible',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#16a34a',
    cancelButtonColor: '#dc2626',
    confirmButtonText: 'Oui, supprimer',
    cancelButtonText: 'Annuler'
  })
  
  if (result.isConfirmed) {
    try {
      const config = useRuntimeConfig()
      const token = authStore.token
      await $fetch(`${config.public.apiBase}/villes-crud/${id}`, {
        method: 'DELETE',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/json'
        }
      })
      
      $swal.fire({
        icon: 'success',
        title: 'Supprimé',
        text: 'La ville a été supprimée avec succès',
        timer: 2000,
        showConfirmButton: false
      })
      
      await loadVilles()
    } catch (error) {
      console.error('Erreur lors de la suppression:', error)
      $swal.fire({
        icon: 'error',
        title: 'Erreur',
        text: 'Une erreur est survenue lors de la suppression'
      })
    }
  }
}

// Ouvrir le modal province
function openProvinceModal() {
  if (!form.value.pays_id) {
    const { $swal } = useNuxtApp()
    $swal.fire({
      icon: 'warning',
      title: 'Attention',
      text: 'Veuillez d\'abord sélectionner un pays'
    })
    return
  }
  
  const selectedPays = paysList.value.find(p => p.id == form.value.pays_id)
  provinceForm.value = {
    nom: '',
    pays_nom: selectedPays ? selectedPays.nom : ''
  }
  
  showProvinceModal.value = true
}

// Fermer le modal province
function closeProvinceModal() {
  showProvinceModal.value = false
  provinceForm.value = {
    nom: '',
    pays_nom: ''
  }
}

// Enregistrer une province
async function saveProvince() {
  try {
    const config = useRuntimeConfig()
    const token = authStore.token
    
    const data = {
      nom: provinceForm.value.nom,
      type: 'province',
      pays_nom: provinceForm.value.pays_nom,
      continent: null
    }
    
    const response = await $fetch(`${config.public.apiBase}/regions-crud`, {
      method: 'POST',
      body: data,
      headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json',
        'Content-Type': 'application/json'
      }
    })
    
    const { $swal } = useNuxtApp()
    $swal.fire({
      icon: 'success',
      title: 'Succès',
      text: 'Province ajoutée avec succès',
      timer: 2000,
      showConfirmButton: false
    })
    
    closeProvinceModal()
    
    // Recharger les provinces et mettre à jour le filtre
    await loadProvinces()
    filterProvincesByPays()
    
    // Sélectionner automatiquement la nouvelle province
    if (response && response.id) {
      form.value.region_id = response.id
    }
  } catch (error) {
    console.error('Erreur lors de l\'enregistrement:', error)
    const { $swal } = useNuxtApp()
    $swal.fire({
      icon: 'error',
      title: 'Erreur',
      text: 'Une erreur est survenue lors de l\'enregistrement'
    })
  }
}

// Obtenir le nom du pays sélectionné
function getSelectedPaysName() {
  if (!form.value.pays_id) return ''
  const selectedPays = paysList.value.find(p => p.id == form.value.pays_id)
  return selectedPays ? selectedPays.nom : ''
}

// Initialisation
onMounted(async () => {
  await Promise.all([loadVilles(), loadPays(), loadProvinces()])
})
</script>
