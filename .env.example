DB_HOST=localhost
DB_NAME=gestion_dignitaire
DB_USER=root
DB_PASS=root
DB_PORT=3306

# Environnement (development, production)
APP_ENV=development

# Clé secrète pour CSRF (générer une clé aléatoire unique)
APP_SECRET_KEY=changez_cette_cle_secrete_par_une_valeur_aleatoire

# Logging
LOG_LEVEL=INFO

# Session (en secondes)
SESSION_TIMEOUT=1800

# Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx
